{
  "name": "@areasong/areaforge",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter @areaforge/web dev",
    "build": "pnpm --filter @areaforge/web build",
    "start": "pnpm --filter @areaforge/web start",
    "lint": "pnpm --filter @areaforge/web lint",
    "typecheck": "pnpm db:generate && pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "check": "pnpm typecheck && pnpm lint && pnpm db:validate && pnpm build",
    "docs:readiness": "tsx scripts/quality/docs-100-readiness.ts",
    "docs:completion": "tsx scripts/quality/docs-100-completion.ts",
    "risk:preflight": "tsx scripts/quality/risk-preflight.ts",
    "package-d:preflight": "tsx scripts/quality/package-d-preflight.ts",
    "package-e:preflight": "tsx scripts/quality/package-e-preflight.ts",
    "github-release-updater:preflight": "tsx scripts/quality/github-release-updater-preflight.ts",
    "shellcheck:updater": "shellcheck ops/github-release-updater/areaforge-updater.sh ops/update-agent/areaforge-update-agent.sh",
    "release:evidence:validate": "tsx scripts/quality/release-evidence-validate.ts",
    "release:evidence:selftest": "tsx scripts/quality/release-evidence-validate.selftest.ts",
    "auth:hash": "tsx scripts/auth/hash-password.ts",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://areaforge:areaforge@127.0.0.1:54329/areaforge} prisma generate",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://areaforge:areaforge@127.0.0.1:54329/areaforge} prisma validate",
    "db:migrate:diff:empty": "DATABASE_URL=${DATABASE_URL:-postgresql://areaforge:areaforge@127.0.0.1:54329/areaforge} prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script",
    "db:migrate:dev": "DATABASE_URL=${DATABASE_URL:-postgresql://areaforge:areaforge@127.0.0.1:54329/areaforge} prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/db/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "dotenv": "^17.2.3",
    "prisma": "^7.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
