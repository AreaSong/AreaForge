generator client {
  provider = "prisma-client"
  output   = "../packages/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubjectCode {
  MATH
  ENGLISH
  POLITICS
  DATA_STRUCTURE
  COMPUTER_ORGANIZATION
  OPERATING_SYSTEM
  COMPUTER_NETWORK
}

enum ExamWorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
  DEFERRED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskDebtStatus {
  NONE
  ACCEPTABLE
  NEEDS_RECOVERY
  STAGE_IMPACT
  PLAN_BREAKING
}

enum StudySessionStatus {
  RUNNING
  PAUSED
  COMPLETED
  CANCELED
}

enum StudySessionStartSource {
  TASK
  SUBJECT_SHORTCUT
  RECOVERY
}

enum SyllabusNodeKind {
  SUBJECT
  CHAPTER
  TOPIC
  PROBLEM_TYPE
}

enum SyllabusNodeStatus {
  NOT_STARTED
  LEARNING
  COVERED
  NEEDS_REVIEW
  MASTERED
  WEAK
  DEFERRED
}

enum MasteryLevel {
  SEEN
  LEARNED
  BASIC_EXERCISES
  CAN_EXPLAIN
  RETEST_PASSED
  EXAM_STABLE
}

enum MistakeCause {
  UNKNOWN
  CONCEPT_CONFUSION
  FORMULA_UNFAMILIAR
  WRONG_APPROACH
  CARELESS
  TIME_PRESSURE
  UNFAMILIAR_PATTERN
}

enum NoteKind {
  GENERAL
  CONCEPT
  METHOD
  EXAMPLE
  JOURNAL
  SUMMARY
}

enum TaskDependencyType {
  SOFT
  HARD
}

enum PlanInboxItemStatus {
  OPEN
  DISMISSED
  CONVERTED
}

enum PlanInboxDependencyTargetType {
  TASK
  INBOX_STABLE_REF
}

enum StudyResourceSourceType {
  FILE
  LINK
}

enum StudyResourceCategory {
  TEXTBOOK
  COURSE
  EXERCISE
  PAST_PAPER
  SOLUTION
  SUMMARY
  IMAGE
  OTHER
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  auditEvents             AuditEvent[]
  sessions                AuthSession[]
  taskDebtEvents          TaskDebtEvent[]
  recoveryStates          RecoveryState[]
  masteryConditions       MasteryConditionRecord[]
  masteryEvidence         MasteryEvidence[]
  masteryRetests          MasteryRetest[]
  stageAdjustmentDrafts   StageAdjustmentDraft[]
  periodicReportDecisions PeriodicReportDecision[]
  examWorkspaces          ExamWorkspace[]
  taskDependencies        TaskDependency[]
  planInboxItems          PlanInboxItem[]
  learningTreeImportBatches LearningTreeImportBatch[]
  recoveryStatesAsUser    RecoveryState[]          @relation("RecoveryStateUser")
  reviewSchedules         ReviewSchedule[]
  reviewEvents            ReviewEvent[]
  knowledgeCanvasLayouts  KnowledgeCanvasLayout[]
  motivationItems         MotivationItem[]
  motivationReminderState MotivationReminderState?
  notificationPreference  NotificationPreference?
  aiDraftOperations       AiDraftOperation[]
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ExamWorkspace {
  id               String              @id @default(cuid())
  userId           String
  stableKey        String
  name             String
  targetExamDate   DateTime?
  stageSummary     String?
  status           ExamWorkspaceStatus @default(ACTIVE)
  revision         Int                 @default(1)
  archivedAt       DateTime?
  archivedByUserId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectGroups    SubjectGroup[]
  subjects         Subject[]
  stagePlans       StagePlan[]
  dailyReviews     DailyReview[]
  checkIns         CheckIn[]
  recoveryStates   RecoveryState[]
  simulationExams  SimulationExam[]
  stageAdjustmentDrafts StageAdjustmentDraft[]
  periodicReportDecisions PeriodicReportDecision[]
  planMilestones   PlanMilestone[]
  planInboxItems   PlanInboxItem[]
  studyResources   StudyResource[]
  learningTreeImportBatches LearningTreeImportBatch[]
  reviewSchedules  ReviewSchedule[]
  knowledgeCanvasLayouts KnowledgeCanvasLayout[]
  aiDraftOperations AiDraftOperation[]

  @@unique([userId, stableKey])
  @@index([userId])
  @@index([status])
}

model SubjectGroup {
  id          String         @id @default(cuid())
  workspaceId String
  stableKey   String
  name        String
  sortOrder   Int            @default(0)
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   ExamWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subjects    Subject[]

  @@unique([workspaceId, stableKey])
  @@index([workspaceId])
}

model Subject {
  id                       String                    @id @default(cuid())
  legacyCode               SubjectCode?
  workspaceId              String?
  groupId                  String?
  stableKey                String
  name                     String
  color                    String
  sortOrder                Int                       @default(0)
  archivedAt               DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  workspace                ExamWorkspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  group                    SubjectGroup?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  tasks                    StudyTask[]
  sessions                 StudySession[]
  syllabusNodes            SyllabusNode[]
  notes                    Note[]
  mistakes                 Mistake[]
  simulationSubjectResults SimulationSubjectResult[]
  planMilestones           PlanMilestone[]
  studyResources           StudyResource[]

  @@index([workspaceId])
  @@index([groupId])
  @@index([stableKey])
  @@index([legacyCode])
}

model SyllabusNode {
  id            String             @id @default(cuid())
  subjectId     String
  parentId      String?
  title         String
  kind          SyllabusNodeKind
  status        SyllabusNodeStatus @default(NOT_STARTED)
  masteryLevel  MasteryLevel?
  sortOrder     Int                @default(0)
  targetMinutes Int                @default(0)
  actualMinutes Int                @default(0)
  stableKey     String?
  revision      Int                @default(1)
  archivedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subject       Subject            @relation(fields: [subjectId], references: [id])
  parent        SyllabusNode?      @relation("SyllabusTree", fields: [parentId], references: [id])
  children      SyllabusNode[]     @relation("SyllabusTree")
  tasks         StudyTask[]
  sessions      StudySession[]
  notes         Note[]
  mistakes      Mistake[]
  masteryConditions MasteryConditionRecord[]
  masteryEvidence   MasteryEvidence[]
  masteryRetests    MasteryRetest[]
  relatedNotes      NoteRelatedSyllabusNode[]
  relatedTasks      StudyTaskRelatedSyllabusNode[]
  studyResourceLinks StudyResourceSyllabusNodeLink[]
  reviewSchedules   ReviewSchedule[]

  @@unique([subjectId, stableKey])
  @@index([subjectId])
  @@index([parentId])
  @@index([archivedAt])
}

model StudyTask {
  id                String          @id @default(cuid())
  subjectId         String
  syllabusNodeId    String?
  parentTaskId      String?
  planMilestoneId   String?
  reviewScheduleId  String?
  title             String
  type              String
  status            TaskStatus      @default(TODO)
  priority          TaskPriority    @default(MEDIUM)
  debtStatus        TaskDebtStatus  @default(NONE)
  plannedDate       DateTime
  estimatedMinutes  Int             @default(0)
  actualMinutes     Int             @default(0)
  reviewText        String?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  subject           Subject         @relation(fields: [subjectId], references: [id])
  syllabusNode      SyllabusNode?   @relation(fields: [syllabusNodeId], references: [id])
  parent            StudyTask?      @relation("TaskTree", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children          StudyTask[]     @relation("TaskTree")
  planMilestone     PlanMilestone?  @relation(fields: [planMilestoneId], references: [id], onDelete: SetNull)
  reviewSchedule    ReviewSchedule? @relation(fields: [reviewScheduleId], references: [id], onDelete: SetNull)
  sessions          StudySession[]
  notes             Note[]
  taskDebtEvents    TaskDebtEvent[] @relation("TaskDebtEventTask")
  relatedDebtEvents TaskDebtEvent[] @relation("RelatedTaskDebtEvent")
  masteryEvidence   MasteryEvidence[]
  relatedSyllabusNodes StudyTaskRelatedSyllabusNode[]
  predecessorDependencies TaskDependency[] @relation("TaskDependencyPredecessor")
  successorDependencies   TaskDependency[] @relation("TaskDependencySuccessor")
  convertedFromInboxItems PlanInboxItem[]
  inboxDependencyRefs     PlanInboxDependencyRef[]
  studyResourceLinks      StudyResourceTaskLink[]

  @@index([plannedDate])
  @@index([subjectId])
  @@index([syllabusNodeId])
  @@index([parentTaskId])
  @@index([planMilestoneId])
  @@index([reviewScheduleId])
}

model StudyTaskRelatedSyllabusNode {
  id             String       @id @default(cuid())
  taskId         String
  syllabusNodeId String
  createdAt      DateTime     @default(now())
  task           StudyTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  syllabusNode   SyllabusNode @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)

  @@unique([taskId, syllabusNodeId])
  @@index([syllabusNodeId])
}

model StudySession {
  id                      String                    @id @default(cuid())
  subjectId               String
  taskId                  String?
  syllabusNodeId          String?
  status                  StudySessionStatus        @default(RUNNING)
  startedAt               DateTime
  pausedAt                DateTime?
  endedAt                 DateTime?
  accumulatedPauseSeconds Int                       @default(0)
  effectiveMinutes        Int                       @default(0)
  qualityScore            Int?
  isEffective             Boolean?
  understandingLevel      String?
  minimalOutput           String?
  nextAction              String?
  producedNote            Boolean                   @default(false)
  producedMistake         Boolean                   @default(false)
  isLowConversion         Boolean?
  antiFakeReason          String?
  requiredOutput          String?
  closeoutVersion         Int                       @default(1)
  note                    String?
  goalMinutes             Int?
  startSource             StudySessionStartSource?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  subject                 Subject                   @relation(fields: [subjectId], references: [id])
  task                    StudyTask?                @relation(fields: [taskId], references: [id])
  syllabusNode            SyllabusNode?             @relation(fields: [syllabusNodeId], references: [id])
  masteryEvidence         MasteryEvidence[]

  @@index([status])
  @@index([startedAt])
  @@index([subjectId])
}

model DailyReview {
  id               String         @id @default(cuid())
  workspaceId      String?
  reviewDate       DateTime
  totalMinutes     Int            @default(0)
  effectiveMinutes Int            @default(0)
  summary          String?
  lostControl      String?
  keepAction       String?
  tomorrowMinimum  String?
  mood             String?
  aiSuggestion     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  workspace        ExamWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([reviewDate])
}

model CheckIn {
  id                     String         @id @default(cuid())
  workspaceId            String?
  studyDate              DateTime
  completedMinimumAction Boolean        @default(false)
  totalMinutes           Int            @default(0)
  effectiveMinutes       Int            @default(0)
  effectiveSessionCount  Int            @default(0)
  taskCompletionRate     Float          @default(0)
  reviewSubmitted        Boolean        @default(false)
  lowEfficiency          Boolean        @default(false)
  lowConversionCount     Int            @default(0)
  sourceVersion          Int            @default(1)
  reviewCount            Int            @default(0)
  reviewSeconds          Int            @default(0)
  passedCount            Int            @default(0)
  partialCount           Int            @default(0)
  failedCount            Int            @default(0)
  minimumActionSource    String         @default("NONE")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  workspace              ExamWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([studyDate])
}

model TaskDebtEvent {
  id             String     @id @default(cuid())
  taskId         String
  actorId        String?
  action         String
  fromStatus     String?
  toStatus       String?
  fromDebtStatus String?
  toDebtStatus   String?
  relatedTaskId  String?
  reason         String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  task           StudyTask  @relation("TaskDebtEventTask", fields: [taskId], references: [id])
  relatedTask    StudyTask? @relation("RelatedTaskDebtEvent", fields: [relatedTaskId], references: [id], onDelete: SetNull)
  actor          User?      @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([relatedTaskId])
  @@index([createdAt])
}

model RecoveryState {
  id                 String         @id @default(cuid())
  workspaceId        String?
  userId             String?
  status             String
  triggerType        String
  startedAt          DateTime       @default(now())
  endedAt            DateTime?
  targetMinutes      Int
  visibleTaskLimit   Int
  reason             String
  exitCondition      String?
  metadata           Json?
  actorId            String?
  currentStage       Int            @default(1)
  windowStartDate    DateTime?
  windowEndDate      DateTime?
  lastProgressDate   DateTime?
  progressionVersion Int            @default(1)
  revision           Int            @default(1)
  actor              User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  user               User?          @relation("RecoveryStateUser", fields: [userId], references: [id], onDelete: SetNull)
  workspace          ExamWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([startedAt])
  @@index([endedAt])
  @@index([actorId])
  @@index([userId])
  @@index([workspaceId])
}

model Note {
  id             String        @id @default(cuid())
  subjectId      String
  syllabusNodeId String?
  taskId         String?
  kind           NoteKind      @default(GENERAL)
  studyDate      DateTime?
  stableKey      String?
  revision       Int           @default(1)
  title          String
  content        String
  masteryStatus  String?
  nextReviewAt   DateTime?
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subject        Subject       @relation(fields: [subjectId], references: [id])
  syllabusNode   SyllabusNode? @relation(fields: [syllabusNodeId], references: [id])
  task           StudyTask?    @relation(fields: [taskId], references: [id])
  attachments    Attachment[]
  masteryEvidence MasteryEvidence[]
  relatedSyllabusNodes NoteRelatedSyllabusNode[]
  studyResourceLinks StudyResourceNoteLink[]
  reviewSchedules ReviewSchedule[]

  @@index([subjectId])
  @@index([syllabusNodeId])
  @@index([stableKey])
  @@index([kind])
  @@index([archivedAt])
}

model NoteRelatedSyllabusNode {
  id             String       @id @default(cuid())
  noteId         String
  syllabusNodeId String
  createdAt      DateTime     @default(now())
  note           Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  syllabusNode   SyllabusNode @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)

  @@unique([noteId, syllabusNodeId])
  @@index([syllabusNodeId])
}

enum AttachmentStatus {
  PENDING
  READY
  FAILED
}

model Attachment {
  id                           String           @id @default(cuid())
  noteId                       String?
  originalName                 String
  storedName                   String           @unique
  mimeType                     String
  sizeBytes                    Int
  hash                         String
  uri                          String           @unique
  status                       AttachmentStatus @default(PENDING)
  protocolVersion              Int              @default(1)
  stagingName                  String?          @unique
  finalizedAt                  DateTime?
  failureCode                  String?
  failurePhase                 String?
  reconciliationClaimId        String?
  reconciliationClaimedAt      DateTime?
  reconciliationLeaseExpiresAt DateTime?
  reconciliationAttempt        Int              @default(0)
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt
  note                         Note?            @relation(fields: [noteId], references: [id])
  studyResource                StudyResource?

  @@index([hash])
  @@index([noteId])
  @@index([status, createdAt])
}

model Mistake {
  id             String        @id @default(cuid())
  subjectId      String
  syllabusNodeId String?
  title          String
  source         String?
  cause          MistakeCause  @default(UNKNOWN)
  correctIdea    String?
  nextReviewAt   DateTime?
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subject        Subject       @relation(fields: [subjectId], references: [id])
  syllabusNode   SyllabusNode? @relation(fields: [syllabusNodeId], references: [id])
  masteryEvidence MasteryEvidence[]
  studyResourceLinks StudyResourceMistakeLink[]
  reviewSchedules ReviewSchedule[]

  @@index([subjectId])
  @@index([syllabusNodeId])
  @@index([nextReviewAt])
  @@index([archivedAt])
}

model MotivationVault {
  id                   String   @id @default(cuid())
  whyStarted           String?
  neverReturnTo        String?
  futureSelf           String?
  messageToFuture      String?
  firstSimulationDiary String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
}

model PeriodicReportDecision {
  id                       String         @id @default(cuid())
  workspaceId              String?
  kind                     String
  rangeStart               DateTime
  rangeEnd                 DateTime
  status                   String
  reportSnapshot           Json
  nextCycleDraft           Json?
  canAutoApply             Boolean        @default(false)
  requiresUserConfirmation Boolean        @default(true)
  actorId                  String?
  decidedAt                DateTime       @default(now())
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  actor                    User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  workspace                ExamWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([kind])
  @@index([status])
  @@index([decidedAt])
  @@index([actorId])
  @@index([workspaceId])
}

model MasteryConditionRecord {
  id             String       @id @default(cuid())
  syllabusNodeId String
  condition      String
  checked        Boolean      @default(false)
  checkedAt      DateTime?
  actorId        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  syllabusNode   SyllabusNode @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([syllabusNodeId, condition])
  @@index([syllabusNodeId])
  @@index([actorId])
}

model MasteryEvidence {
  id             String         @id @default(cuid())
  syllabusNodeId String
  evidenceType   String
  taskId         String?
  sessionId      String?
  noteId         String?
  mistakeId      String?
  retestId       String?
  summary        String?
  createdAt      DateTime       @default(now())
  actorId        String?
  syllabusNode   SyllabusNode   @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  task           StudyTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  session        StudySession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  note           Note?          @relation(fields: [noteId], references: [id], onDelete: SetNull)
  mistake        Mistake?       @relation(fields: [mistakeId], references: [id], onDelete: SetNull)
  retest         MasteryRetest? @relation(fields: [retestId], references: [id], onDelete: SetNull)
  actor          User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([syllabusNodeId])
  @@index([evidenceType])
  @@index([taskId])
  @@index([sessionId])
  @@index([noteId])
  @@index([mistakeId])
  @@index([retestId])
  @@index([actorId])
  @@index([createdAt])
}

model MasteryRetest {
  id             String            @id @default(cuid())
  syllabusNodeId String
  testedAt       DateTime
  result         String
  score          String?
  summary        String?
  nextReviewAt   DateTime?
  reviewEventId  String?           @unique
  actorId        String?
  createdAt      DateTime          @default(now())
  syllabusNode   SyllabusNode      @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  evidence       MasteryEvidence[]
  reviewEvent    ReviewEvent?      @relation(fields: [reviewEventId], references: [id], onDelete: SetNull)
  actor          User?             @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([syllabusNodeId])
  @@index([testedAt])
  @@index([result])
  @@index([nextReviewAt])
  @@index([actorId])
}

model SimulationExam {
  id                    String                    @id @default(cuid())
  workspaceId           String?
  name                  String
  examDate              DateTime
  isFirstSynchronized   Boolean                   @default(false)
  targetDurationMinutes Int?
  actualDurationMinutes Int?
  targetScore           Float?
  actualScore           Float?
  blankQuestionCount    Int                       @default(0)
  lossReasons           Json?
  mindset               String?
  summary               String?
  reviewText            String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  workspace             ExamWorkspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  subjectResults        SimulationSubjectResult[]

  @@index([examDate])
  @@index([isFirstSynchronized])
  @@index([workspaceId])
}

model SimulationSubjectResult {
  id                 String         @id @default(cuid())
  simulationExamId   String
  subjectId          String
  targetScore        Float?
  actualScore        Float?
  durationMinutes    Int?
  blankQuestionCount Int            @default(0)
  lossReasons        Json?
  summary            String?
  simulationExam     SimulationExam @relation(fields: [simulationExamId], references: [id], onDelete: Cascade)
  subject            Subject        @relation(fields: [subjectId], references: [id])

  @@unique([simulationExamId, subjectId])
  @@index([simulationExamId])
  @@index([subjectId])
}

model StagePlan {
  id               String                 @id @default(cuid())
  workspaceId      String?
  stableKey        String?
  revision         Int                    @default(1)
  name             String
  startDate        DateTime
  endDate          DateTime
  goal             String
  mode             String
  status           String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  workspace        ExamWorkspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  adjustmentDrafts StageAdjustmentDraft[]
  planMilestones   PlanMilestone[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([workspaceId])
}

model StageAdjustmentDraft {
  id                       String         @id @default(cuid())
  workspaceId              String?
  stagePlanId              String?
  source                   String
  mode                     String
  risk                     String
  riskConclusion           String
  focusSubjects            Json
  taskIntensity            String
  taskAdjustmentActions    Json
  nextStageEmphasis        String
  canAutoApply             Boolean        @default(false)
  requiresUserConfirmation Boolean        @default(true)
  status                   String
  createdAt                DateTime       @default(now())
  appliedAt                DateTime?
  actorId                  String?
  stagePlan                StagePlan?     @relation(fields: [stagePlanId], references: [id], onDelete: SetNull)
  actor                    User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  workspace                ExamWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([stagePlanId])
  @@index([status])
  @@index([createdAt])
  @@index([actorId])
  @@index([workspaceId])
}

model PlanMilestone {
  id          String         @id @default(cuid())
  workspaceId String
  stagePlanId String
  subjectId   String?
  stableKey   String
  title       String
  targetDate  DateTime?
  sortOrder   Int            @default(0)
  status      String         @default("OPEN")
  revision    Int            @default(1)
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   ExamWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stagePlan   StagePlan      @relation(fields: [stagePlanId], references: [id], onDelete: Cascade)
  subject     Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  tasks       StudyTask[]
  inboxItems  PlanInboxItem[]

  @@unique([workspaceId, stableKey])
  @@index([stagePlanId])
  @@index([subjectId])
  @@index([status])
}

model TaskDependency {
  id            String             @id @default(cuid())
  predecessorId String
  successorId   String
  type          TaskDependencyType @default(SOFT)
  revision      Int                @default(1)
  actorId       String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  predecessor   StudyTask          @relation("TaskDependencyPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     StudyTask          @relation("TaskDependencySuccessor", fields: [successorId], references: [id], onDelete: Cascade)
  actor         User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([predecessorId, successorId])
  @@index([successorId])
  @@index([actorId])
}

model PlanInboxItem {
  id                 String             @id @default(cuid())
  workspaceId        String
  stableKey          String
  originKey          String
  originVersion      Int
  originType         String
  originSnapshot     Json
  status             PlanInboxItemStatus @default(OPEN)
  title              String
  subjectId          String?
  plannedDate        DateTime?
  estimatedMinutes   Int?
  priority           String?
  type               String?
  planMilestoneId    String?
  primaryNodeId      String?
  relatedNodeIds     Json?
  revision           Int                @default(1)
  convertedTaskId    String?            @unique
  supersededByItemId String?
  actorId            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  dismissedAt        DateTime?
  convertedAt        DateTime?
  workspace          ExamWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planMilestone      PlanMilestone?     @relation(fields: [planMilestoneId], references: [id], onDelete: SetNull)
  convertedTask      StudyTask?         @relation(fields: [convertedTaskId], references: [id], onDelete: SetNull)
  supersededByItem   PlanInboxItem?     @relation("PlanInboxSupersede", fields: [supersededByItemId], references: [id], onDelete: SetNull)
  supersedesItems    PlanInboxItem[]    @relation("PlanInboxSupersede")
  actor              User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)
  dependencyRefs     PlanInboxDependencyRef[]

  @@unique([workspaceId, originKey, originVersion])
  @@unique([workspaceId, stableKey])
  @@index([workspaceId, status])
  @@index([planMilestoneId])
  @@index([actorId])
  @@index([supersededByItemId])
}

model PlanInboxDependencyRef {
  id               String                         @id @default(cuid())
  inboxItemId      String
  targetType       PlanInboxDependencyTargetType
  dependencyType   TaskDependencyType             @default(SOFT)
  taskId           String?
  importBatchId    String?
  planStableKey    String?
  planOriginVersion Int?
  createdAt        DateTime                       @default(now())
  inboxItem        PlanInboxItem                  @relation(fields: [inboxItemId], references: [id], onDelete: Cascade)
  task             StudyTask?                     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([inboxItemId])
  @@index([taskId])
  @@index([importBatchId, planStableKey])
}

model StudyResource {
  id                    String                 @id @default(cuid())
  workspaceId           String
  stableKey             String
  title                 String
  category              StudyResourceCategory  @default(OTHER)
  sourceType            StudyResourceSourceType
  subjectId             String?
  attachmentId          String?                @unique
  externalUrl           String?
  displayHost           String?
  duplicateOfResourceId String?
  revision              Int                    @default(1)
  archivedAt            DateTime?
  actorId               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  workspace             ExamWorkspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subject               Subject?               @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  attachment            Attachment?            @relation(fields: [attachmentId], references: [id], onDelete: Restrict)
  duplicateOf           StudyResource?         @relation("StudyResourceDuplicate", fields: [duplicateOfResourceId], references: [id], onDelete: SetNull)
  duplicates            StudyResource[]        @relation("StudyResourceDuplicate")
  tags                  StudyResourceTag[]
  taskLinks             StudyResourceTaskLink[]
  noteLinks             StudyResourceNoteLink[]
  mistakeLinks          StudyResourceMistakeLink[]
  syllabusNodeLinks     StudyResourceSyllabusNodeLink[]
  reviewSchedules       ReviewSchedule[]

  @@unique([workspaceId, stableKey])
  @@index([workspaceId])
  @@index([subjectId])
  @@index([sourceType])
  @@index([archivedAt])
  @@index([duplicateOfResourceId])
}

model StudyResourceTag {
  id         String        @id @default(cuid())
  resourceId String
  tagNorm    String
  tagDisplay String
  createdAt  DateTime      @default(now())
  resource   StudyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, tagNorm])
  @@index([resourceId])
}

model StudyResourceTaskLink {
  id         String        @id @default(cuid())
  resourceId String
  taskId     String
  createdAt  DateTime      @default(now())
  resource   StudyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  task       StudyTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([resourceId, taskId])
  @@index([taskId])
}

model StudyResourceNoteLink {
  id         String        @id @default(cuid())
  resourceId String
  noteId     String
  createdAt  DateTime      @default(now())
  resource   StudyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  note       Note          @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([resourceId, noteId])
  @@index([noteId])
}

model StudyResourceMistakeLink {
  id         String        @id @default(cuid())
  resourceId String
  mistakeId  String
  createdAt  DateTime      @default(now())
  resource   StudyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  mistake    Mistake       @relation(fields: [mistakeId], references: [id], onDelete: Cascade)

  @@unique([resourceId, mistakeId])
  @@index([mistakeId])
}

model StudyResourceSyllabusNodeLink {
  id             String        @id @default(cuid())
  resourceId     String
  syllabusNodeId String
  createdAt      DateTime      @default(now())
  resource       StudyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  syllabusNode   SyllabusNode  @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)

  @@unique([resourceId, syllabusNodeId])
  @@index([syllabusNodeId])
}

model LearningTreeImportBatch {
  id                 String   @id @default(cuid())
  workspaceId        String
  protocolVersion    String
  parserVersion      String
  scope              String
  canonicalMarkdown  String
  sourceSha256       String
  canonicalPlanHash  String
  rootRevision       Int
  statsJson          Json
  resultJson         Json
  idempotencyKey     String
  requestFingerprint String
  previewNonce       String
  previewOperationId String?
  archivedAt         DateTime?
  actorId            String?
  confirmedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  workspace          ExamWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor              User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)
  items              LearningTreeImportItem[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, confirmedAt])
  @@index([actorId])
  @@index([archivedAt])
  @@index([previewNonce])
}

model LearningTreeImportItem {
  id                String   @id @default(cuid())
  batchId           String
  stableRef         String
  objectType        String
  diffType          String
  sourceLine        Int?
  sourceTargetKey   String?
  mappedTargetId    String?
  mappedTargetKey   String?
  userChoice        String
  applyResult       String
  redactedErrorCode String?
  createdAt         DateTime @default(now())
  batch             LearningTreeImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([stableRef])
  @@index([objectType])
}

model ReviewSchedule {
  id                   String         @id @default(cuid())
  workspaceId          String
  targetType           String
  noteId               String?
  mistakeId            String?
  studyResourceId      String?
  syllabusNodeId       String?
  status               String         @default("ACTIVE")
  dueDate              DateTime?
  pausedReason         String?
  consecutivePassCount Int            @default(0)
  revision             Int            @default(1)
  actorId              String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  workspace            ExamWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  note                 Note?          @relation(fields: [noteId], references: [id], onDelete: Cascade)
  mistake              Mistake?       @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  studyResource        StudyResource? @relation(fields: [studyResourceId], references: [id], onDelete: Cascade)
  syllabusNode         SyllabusNode?  @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  actor                User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  events               ReviewEvent[]
  bridgeTasks          StudyTask[]

  @@index([workspaceId, status, dueDate])
  @@index([actorId])
}

model ReviewEvent {
  id                   String         @id @default(cuid())
  reviewScheduleId     String
  idempotencyKey       String
  requestFingerprint   String
  expectedRevision     Int
  appliedRevision      Int
  result               String
  durationSeconds      Int
  confirmedAt          DateTime       @default(now())
  learningDate         DateTime
  nextDueDate          DateTime
  consecutivePassDelta Int            @default(0)
  correctedEventId     String?
  note                 String?
  actorId              String?
  createdAt            DateTime       @default(now())
  reviewSchedule       ReviewSchedule @relation(fields: [reviewScheduleId], references: [id], onDelete: Cascade)
  correctedEvent       ReviewEvent?   @relation("ReviewEventCorrection", fields: [correctedEventId], references: [id], onDelete: SetNull)
  corrections          ReviewEvent[]  @relation("ReviewEventCorrection")
  actor                User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  masteryRetest        MasteryRetest?

  @@unique([reviewScheduleId, idempotencyKey])
  @@index([reviewScheduleId, confirmedAt])
  @@index([learningDate])
  @@index([correctedEventId])
  @@index([actorId])
}

enum MotivationItemType {
  QUOTE
  VIDEO_LINK
  VAULT_EXCERPT
}

enum AiDraftOperationStatus {
  PENDING
  IN_FLIGHT
  SUCCEEDED
  FAILED
  EXPIRED
}

enum KnowledgeCanvasEntityType {
  WORKSPACE
  SUBJECT_GROUP
  SUBJECT
  SYLLABUS_NODE
  NOTE
  MISTAKE
  STUDY_RESOURCE
  TASK
  MILESTONE
  STUDY_SESSION
  REVIEW_SCHEDULE
}

model KnowledgeCanvasLayout {
  id           String                     @id @default(cuid())
  userId       String
  workspaceId  String
  viewportX    Float                      @default(0)
  viewportY    Float                      @default(0)
  viewportZoom Float                      @default(1)
  revision     Int                        @default(1)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    ExamWorkspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodes        KnowledgeCanvasNodeLayout[]

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model KnowledgeCanvasNodeLayout {
  id         String                    @id @default(cuid())
  layoutId   String
  entityType KnowledgeCanvasEntityType
  entityId   String
  x          Float
  y          Float
  collapsed  Boolean                   @default(false)
  pinned     Boolean                   @default(false)
  hidden     Boolean                   @default(false)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  layout     KnowledgeCanvasLayout     @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@unique([layoutId, entityType, entityId])
  @@index([entityType, entityId])
}

model MotivationItem {
  id              String             @id @default(cuid())
  userId          String
  type            MotivationItemType
  title           String
  body            String?
  externalUrl     String?
  vaultSourceId   String?
  tags            String[]           @default([])
  enabled         Boolean            @default(true)
  sortOrder       Int                @default(0)
  revision        Int                @default(1)
  actorId         String?
  archivedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled, sortOrder])
  @@index([archivedAt])
}

model MotivationReminderState {
  id               String    @id @default(cuid())
  userId           String    @unique
  lastAutoShowAt   DateTime?
  learningDay      DateTime?
  dailyCount       Int       @default(0)
  recentItemIds    String[]  @default([])
  revision         Int       @default(1)
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  reviewDueEnabled   Boolean  @default(true)
  planStartEnabled   Boolean  @default(true)
  eveningReviewEnabled Boolean @default(true)
  reviewDueWindowStart Int    @default(8)
  reviewDueWindowEnd   Int    @default(22)
  planStartWindowStart Int    @default(7)
  planStartWindowEnd   Int    @default(21)
  eveningReviewWindowStart Int @default(20)
  eveningReviewWindowEnd   Int @default(23)
  quietHoursStart    Int?
  quietHoursEnd      Int?
  revision           Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiDraftOperation {
  id                 String                 @id @default(cuid())
  operationId        String
  actorId            String
  workspaceId        String
  endpoint           String
  purpose            String
  requestFingerprint String
  nonce              String
  projectionVersion  String
  status             AiDraftOperationStatus @default(PENDING)
  resultReference    String?
  expiresAt          DateTime
  consumedAt         DateTime?
  revision           Int                    @default(1)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  actor              User                   @relation(fields: [actorId], references: [id], onDelete: Cascade)
  workspace          ExamWorkspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, operationId])
  @@unique([workspaceId, endpoint, nonce])
  @@index([actorId])
  @@index([status, expiresAt])
}
