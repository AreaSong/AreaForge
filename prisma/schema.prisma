generator client {
  provider = "prisma-client"
  output   = "../packages/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubjectCode {
  MATH
  ENGLISH
  POLITICS
  DATA_STRUCTURE
  COMPUTER_ORGANIZATION
  OPERATING_SYSTEM
  COMPUTER_NETWORK
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
  DEFERRED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskDebtStatus {
  NONE
  ACCEPTABLE
  NEEDS_RECOVERY
  STAGE_IMPACT
  PLAN_BREAKING
}

enum StudySessionStatus {
  RUNNING
  PAUSED
  COMPLETED
  CANCELED
}

enum SyllabusNodeKind {
  SUBJECT
  CHAPTER
  TOPIC
  PROBLEM_TYPE
}

enum SyllabusNodeStatus {
  NOT_STARTED
  LEARNING
  COVERED
  NEEDS_REVIEW
  MASTERED
  WEAK
  DEFERRED
}

enum MasteryLevel {
  SEEN
  LEARNED
  BASIC_EXERCISES
  CAN_EXPLAIN
  RETEST_PASSED
  EXAM_STABLE
}

enum MistakeCause {
  UNKNOWN
  CONCEPT_CONFUSION
  FORMULA_UNFAMILIAR
  WRONG_APPROACH
  CARELESS
  TIME_PRESSURE
  UNFAMILIAR_PATTERN
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  auditEvents    AuditEvent[]
  sessions       AuthSession[]
  taskDebtEvents TaskDebtEvent[]
  recoveryStates RecoveryState[]
  masteryConditions MasteryConditionRecord[]
  masteryEvidence   MasteryEvidence[]
  masteryRetests    MasteryRetest[]
  stageAdjustmentDrafts StageAdjustmentDraft[]
  periodicReportDecisions PeriodicReportDecision[]
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Subject {
  id            String         @id @default(cuid())
  code          SubjectCode    @unique
  name          String
  color         String
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         StudyTask[]
  sessions      StudySession[]
  syllabusNodes SyllabusNode[]
  notes         Note[]
  mistakes      Mistake[]
  simulationSubjectResults SimulationSubjectResult[]
}

model SyllabusNode {
  id            String             @id @default(cuid())
  subjectId     String
  parentId      String?
  title         String
  kind          SyllabusNodeKind
  status        SyllabusNodeStatus @default(NOT_STARTED)
  masteryLevel  MasteryLevel?
  sortOrder     Int                @default(0)
  targetMinutes Int                @default(0)
  actualMinutes Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subject       Subject            @relation(fields: [subjectId], references: [id])
  parent        SyllabusNode?      @relation("SyllabusTree", fields: [parentId], references: [id])
  children      SyllabusNode[]     @relation("SyllabusTree")
  tasks         StudyTask[]
  sessions      StudySession[]
  notes         Note[]
  mistakes      Mistake[]
  masteryConditions MasteryConditionRecord[]
  masteryEvidence   MasteryEvidence[]
  masteryRetests    MasteryRetest[]

  @@index([subjectId])
  @@index([parentId])
}

model StudyTask {
  id                String          @id @default(cuid())
  subjectId         String
  syllabusNodeId    String?
  parentTaskId      String?
  title             String
  type              String
  status            TaskStatus      @default(TODO)
  priority          TaskPriority    @default(MEDIUM)
  debtStatus        TaskDebtStatus  @default(NONE)
  plannedDate       DateTime
  estimatedMinutes  Int             @default(0)
  actualMinutes     Int             @default(0)
  reviewText        String?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  subject           Subject         @relation(fields: [subjectId], references: [id])
  syllabusNode      SyllabusNode?   @relation(fields: [syllabusNodeId], references: [id])
  parent            StudyTask?      @relation("TaskTree", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children          StudyTask[]     @relation("TaskTree")
  sessions          StudySession[]
  notes             Note[]
  taskDebtEvents    TaskDebtEvent[] @relation("TaskDebtEventTask")
  relatedDebtEvents TaskDebtEvent[] @relation("RelatedTaskDebtEvent")
  masteryEvidence   MasteryEvidence[]

  @@index([plannedDate])
  @@index([subjectId])
  @@index([syllabusNodeId])
  @@index([parentTaskId])
}

model StudySession {
  id                      String             @id @default(cuid())
  subjectId               String
  taskId                  String?
  syllabusNodeId          String?
  status                  StudySessionStatus @default(RUNNING)
  startedAt               DateTime
  pausedAt                DateTime?
  endedAt                 DateTime?
  accumulatedPauseSeconds Int                @default(0)
  effectiveMinutes        Int                @default(0)
  qualityScore            Int?
  isEffective             Boolean?
  understandingLevel      String?
  minimalOutput           String?
  nextAction              String?
  producedNote            Boolean            @default(false)
  producedMistake         Boolean            @default(false)
  isLowConversion         Boolean?
  antiFakeReason          String?
  requiredOutput          String?
  closeoutVersion         Int                @default(1)
  note                    String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  subject                 Subject            @relation(fields: [subjectId], references: [id])
  task                    StudyTask?         @relation(fields: [taskId], references: [id])
  syllabusNode            SyllabusNode?      @relation(fields: [syllabusNodeId], references: [id])
  masteryEvidence         MasteryEvidence[]

  @@index([status])
  @@index([startedAt])
  @@index([subjectId])
}

model DailyReview {
  id               String   @id @default(cuid())
  reviewDate       DateTime @unique
  totalMinutes     Int      @default(0)
  effectiveMinutes Int      @default(0)
  summary          String?
  lostControl      String?
  keepAction       String?
  tomorrowMinimum  String?
  mood             String?
  aiSuggestion     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CheckIn {
  id                     String   @id @default(cuid())
  studyDate              DateTime @unique
  completedMinimumAction Boolean  @default(false)
  totalMinutes           Int      @default(0)
  effectiveMinutes       Int      @default(0)
  effectiveSessionCount  Int      @default(0)
  taskCompletionRate     Float    @default(0)
  reviewSubmitted        Boolean  @default(false)
  lowEfficiency          Boolean  @default(false)
  lowConversionCount     Int      @default(0)
  sourceVersion          Int      @default(1)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model TaskDebtEvent {
  id             String     @id @default(cuid())
  taskId         String
  actorId        String?
  action         String
  fromStatus     String?
  toStatus       String?
  fromDebtStatus String?
  toDebtStatus   String?
  relatedTaskId  String?
  reason         String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  task           StudyTask  @relation("TaskDebtEventTask", fields: [taskId], references: [id])
  relatedTask    StudyTask? @relation("RelatedTaskDebtEvent", fields: [relatedTaskId], references: [id], onDelete: SetNull)
  actor          User?      @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([relatedTaskId])
  @@index([createdAt])
}

model RecoveryState {
  id               String    @id @default(cuid())
  status           String
  triggerType      String
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  targetMinutes    Int
  visibleTaskLimit Int
  reason           String
  exitCondition    String?
  metadata         Json?
  actorId          String?
  actor            User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([startedAt])
  @@index([endedAt])
  @@index([actorId])
}

model Note {
  id             String        @id @default(cuid())
  subjectId      String
  syllabusNodeId String?
  taskId         String?
  title          String
  content        String
  masteryStatus  String?
  nextReviewAt   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subject        Subject       @relation(fields: [subjectId], references: [id])
  syllabusNode   SyllabusNode? @relation(fields: [syllabusNodeId], references: [id])
  task           StudyTask?    @relation(fields: [taskId], references: [id])
  attachments    Attachment[]
  masteryEvidence MasteryEvidence[]

  @@index([subjectId])
  @@index([syllabusNodeId])
}

model Attachment {
  id           String   @id @default(cuid())
  noteId       String?
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  hash         String
  uri          String
  createdAt    DateTime @default(now())
  note         Note?    @relation(fields: [noteId], references: [id])

  @@index([hash])
  @@index([noteId])
}

model Mistake {
  id             String        @id @default(cuid())
  subjectId      String
  syllabusNodeId String?
  title          String
  source         String?
  cause          MistakeCause  @default(UNKNOWN)
  correctIdea    String?
  nextReviewAt   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subject        Subject       @relation(fields: [subjectId], references: [id])
  syllabusNode   SyllabusNode? @relation(fields: [syllabusNodeId], references: [id])
  masteryEvidence MasteryEvidence[]

  @@index([subjectId])
  @@index([syllabusNodeId])
  @@index([nextReviewAt])
}

model MotivationVault {
  id                   String   @id @default(cuid())
  whyStarted           String?
  neverReturnTo        String?
  futureSelf           String?
  messageToFuture      String?
  firstSimulationDiary String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
}

model PeriodicReportDecision {
  id                       String   @id @default(cuid())
  kind                     String
  rangeStart               DateTime
  rangeEnd                 DateTime
  status                   String
  reportSnapshot           Json
  nextCycleDraft           Json?
  canAutoApply             Boolean  @default(false)
  requiresUserConfirmation Boolean  @default(true)
  actorId                  String?
  decidedAt                DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  actor                    User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([kind, rangeStart, rangeEnd])
  @@index([kind])
  @@index([status])
  @@index([decidedAt])
  @@index([actorId])
}

model MasteryConditionRecord {
  id             String       @id @default(cuid())
  syllabusNodeId String
  condition      String
  checked        Boolean      @default(false)
  checkedAt      DateTime?
  actorId        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  syllabusNode   SyllabusNode @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([syllabusNodeId, condition])
  @@index([syllabusNodeId])
  @@index([actorId])
}

model MasteryEvidence {
  id             String         @id @default(cuid())
  syllabusNodeId String
  evidenceType   String
  taskId         String?
  sessionId      String?
  noteId         String?
  mistakeId      String?
  retestId       String?
  summary        String?
  createdAt      DateTime       @default(now())
  actorId        String?
  syllabusNode   SyllabusNode   @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  task           StudyTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  session        StudySession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  note           Note?          @relation(fields: [noteId], references: [id], onDelete: SetNull)
  mistake        Mistake?       @relation(fields: [mistakeId], references: [id], onDelete: SetNull)
  retest         MasteryRetest? @relation(fields: [retestId], references: [id], onDelete: SetNull)
  actor          User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([syllabusNodeId])
  @@index([evidenceType])
  @@index([taskId])
  @@index([sessionId])
  @@index([noteId])
  @@index([mistakeId])
  @@index([retestId])
  @@index([actorId])
  @@index([createdAt])
}

model MasteryRetest {
  id             String            @id @default(cuid())
  syllabusNodeId String
  testedAt       DateTime
  result         String
  score          String?
  summary        String?
  nextReviewAt   DateTime?
  actorId        String?
  createdAt      DateTime          @default(now())
  syllabusNode   SyllabusNode      @relation(fields: [syllabusNodeId], references: [id], onDelete: Cascade)
  evidence       MasteryEvidence[]
  actor          User?             @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([syllabusNodeId])
  @@index([testedAt])
  @@index([result])
  @@index([nextReviewAt])
  @@index([actorId])
}

model SimulationExam {
  id                    String                    @id @default(cuid())
  name                  String
  examDate              DateTime
  isFirstSynchronized   Boolean                   @default(false)
  targetDurationMinutes Int?
  actualDurationMinutes Int?
  targetScore           Float?
  actualScore           Float?
  blankQuestionCount    Int                       @default(0)
  lossReasons           Json?
  mindset               String?
  summary               String?
  reviewText            String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  subjectResults        SimulationSubjectResult[]

  @@index([examDate])
  @@index([isFirstSynchronized])
}

model SimulationSubjectResult {
  id                 String         @id @default(cuid())
  simulationExamId   String
  subjectId          String
  targetScore        Float?
  actualScore        Float?
  durationMinutes    Int?
  blankQuestionCount Int            @default(0)
  lossReasons        Json?
  summary            String?
  simulationExam     SimulationExam @relation(fields: [simulationExamId], references: [id], onDelete: Cascade)
  subject            Subject        @relation(fields: [subjectId], references: [id])

  @@unique([simulationExamId, subjectId])
  @@index([simulationExamId])
  @@index([subjectId])
}

model StagePlan {
  id               String                 @id @default(cuid())
  name             String
  startDate        DateTime
  endDate          DateTime
  goal             String
  mode             String
  status           String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  adjustmentDrafts StageAdjustmentDraft[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model StageAdjustmentDraft {
  id                       String     @id @default(cuid())
  stagePlanId              String?
  source                   String
  mode                     String
  risk                     String
  riskConclusion           String
  focusSubjects            Json
  taskIntensity            String
  taskAdjustmentActions    Json
  nextStageEmphasis        String
  canAutoApply             Boolean    @default(false)
  requiresUserConfirmation Boolean    @default(true)
  status                   String
  createdAt                DateTime   @default(now())
  appliedAt                DateTime?
  actorId                  String?
  stagePlan                StagePlan? @relation(fields: [stagePlanId], references: [id], onDelete: SetNull)
  actor                    User?      @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([stagePlanId])
  @@index([status])
  @@index([createdAt])
  @@index([actorId])
}
