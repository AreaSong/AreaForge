# AreaForge 环境变量模板。逐项说明见 docs/guide/configuration.md。
# 复制为 .env（本地）或服务器上的生产环境文件后逐项替换；密钥不要提交到 Git。

# --- 基础运行 ---
NODE_ENV=development
APP_ENV=development
APP_URL=http://127.0.0.1:3000
# 与根 package.json 版本保持一致；生产由发布流程注入
APP_VERSION=0.1.0

# --- 数据库（POSTGRES_* 供 Docker Compose 启动容器使用）---
DATABASE_URL=postgresql://areaforge:areaforge@127.0.0.1:54329/areaforge
POSTGRES_DB=areaforge
POSTGRES_USER=areaforge
POSTGRES_PASSWORD=areaforge
POSTGRES_PORT=54329
WEB_PORT=3000
# 生产使用带 digest 的不可变镜像引用
AREAFORGE_IMAGE=areaforge-web:0.1.0
# 版本中心读取 update-agent 状态的挂载目录（容器内 / 宿主机）
AREAFORGE_OPS_STATE_DIR=/app/ops-state
AREAFORGE_OPS_STATE_HOST_DIR=/opt/areaforge/ops-state

# --- 认证（AUTH_SESSION_SECRET 至少 32 字符；密码哈希用 pnpm auth:hash 生成）---
AUTH_SESSION_COOKIE_NAME=af_session
AUTH_SESSION_SECRET=replace-with-32-byte-random-secret
AUTH_ADMIN_EMAIL=admin@areasong.local
AUTH_ADMIN_PASSWORD_HASH=replace-with-scrypt-hash

# --- AI（默认关闭；启用需同时配置 BASE_URL/API_KEY/MODEL，OpenAI-compatible）---
AI_ENABLED=false
AI_BASE_URL=https://sub2api.example.com/v1
AI_API_KEY=replace-me
AI_MODEL=replace-me
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
# 以下两项是隐私边界，保持 false；含义见 docs/security/file-ai-safety.md
AI_LOG_PROMPTS=false
AI_ALLOW_SENSITIVE_CONTEXT=false

# --- 上传附件（UPLOAD_DIR 必须在 apps/web/public 之外且应用可写）---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20
ALLOWED_UPLOAD_MIME=image/png,image/jpeg,image/webp,application/pdf

# --- 日志与备份（部署层约定，由服务器侧脚本消费）---
LOG_LEVEL=info
TRUST_PROXY=true
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=14
