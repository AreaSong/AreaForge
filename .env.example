NODE_ENV=development
APP_ENV=development
APP_URL=http://127.0.0.1:3000
APP_VERSION=0.1.0

DATABASE_URL=postgresql://areaforge:areaforge@127.0.0.1:54329/areaforge
POSTGRES_DB=areaforge
POSTGRES_USER=areaforge
POSTGRES_PASSWORD=change-me

NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=replace-with-32-byte-random-secret
AUTH_ADMIN_EMAIL=admin@areasong.local
AUTH_ADMIN_PASSWORD_HASH=replace-with-argon2id-or-bcrypt-hash

AI_ENABLED=false
AI_BASE_URL=https://sub2api.example.com/v1
AI_API_KEY=replace-me
AI_MODEL=replace-me
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
AI_LOG_PROMPTS=false
AI_ALLOW_SENSITIVE_CONTEXT=false

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20
ALLOWED_UPLOAD_MIME=image/png,image/jpeg,image/webp,application/pdf

LOG_LEVEL=info
TRUST_PROXY=true
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=14

