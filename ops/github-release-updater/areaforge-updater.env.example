# AreaForge GitHub Release updater config.
# Copy to /etc/areaforge/updater.env or another private path and chmod 600.

AREAFORGE_GITHUB_REPO=owner/AreaForge
AREAFORGE_RELEASE_CHANNEL=stable
AREAFORGE_RELEASE_MANIFEST_ASSET=areaforge-release-manifest.json
AREAFORGE_RELEASE_CHECKSUM_ASSET=SHA256SUMS
AREAFORGE_RELEASE_SIGNATURE_ASSET=SHA256SUMS.sig

# Optional for private repos or higher GitHub API limits.
AREAFORGE_GITHUB_TOKEN=

# Server deployment paths.
AREAFORGE_DEPLOY_DIR=/opt/areaforge
AREAFORGE_ENV_FILE=/opt/areaforge/.env.production
AREAFORGE_COMPOSE_FILE=/opt/areaforge/docker-compose.prod.yml
AREAFORGE_COMPOSE_PROJECT=areaforge
AREAFORGE_NGINX_CONFIG=/etc/nginx/sites-enabled/areaforge.conf

# Backups and records.
AREAFORGE_BACKUP_DIR=/opt/areaforge/backups
AREAFORGE_UPDATE_RECORD_DIR=/opt/areaforge/backups/github-release-updates
AREAFORGE_UPLOADS_VOLUME=areaforge_areaforge-uploads
AREAFORGE_LOCK_FILE=/opt/areaforge/.areaforge-updater.lock

# Update policy: none, patch, minor, all.
# systemd timer normally runs "run"; with "none" it only records that a newer
# release exists. Use "patch" to auto-apply patch versions.
AREAFORGE_AUTO_APPLY=none
AREAFORGE_ALLOW_PRERELEASE=false
AREAFORGE_ALLOW_COMPOSE_UPDATE=false
AREAFORGE_REQUIRE_SIGNATURE=true

# Signature verification. Use one mode:
# - cosign public key: AREAFORGE_COSIGN_PUBLIC_KEY=/etc/areaforge/cosign.pub
# - gpg: AREAFORGE_GPG_VERIFY=true and import the signer key into root/user keyring.
AREAFORGE_COSIGN_PUBLIC_KEY=
AREAFORGE_GPG_VERIFY=false

# Smoke checks.
# Defaults to http://127.0.0.1:${WEB_PORT:-3000}/api/health after loading
# .env.production. Set this if Nginx/HTTPS should be checked instead.
AREAFORGE_HEALTH_URL=

# Optional extra smoke command. It runs after health succeeds. Keep it local and
# make sure it does not print secrets. The repo provides a read-only HTTP smoke:
#   pnpm smoke:prod-readonly
# Prefer AREAFORGE_SMOKE_PASSWORD_FILE over AREAFORGE_SMOKE_PASSWORD.
AREAFORGE_EXTRA_SMOKE_COMMAND=
AREAFORGE_SMOKE_BASE_URL=
AREAFORGE_SMOKE_EMAIL=
AREAFORGE_SMOKE_PASSWORD_FILE=
AREAFORGE_SMOKE_EXPECTED_VERSION=
AREAFORGE_SMOKE_EXPECTED_AUTO_APPLY=none
AREAFORGE_SMOKE_ATTACHMENT_ID=

# Rollback policy. Default rollback is app image only. Database restore stays
# explicit because migrations should be additive and restoring production data is
# a separate high-risk operation.
AREAFORGE_AUTO_RESTORE_DB_ON_ROLLBACK=false
