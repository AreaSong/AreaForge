# AreaForge alerting config.
# Copy to /etc/areaforge/alerting.env and chmod 600. Never commit the real file.
# The notify helper is read-only: it collects signals and pushes redacted alert
# text. It never runs updater apply, migration, backup, restore or Docker.

# Health endpoint. Prefer the public HTTPS URL so certificate expiry can be
# probed from the same host name.
AREAFORGE_ALERT_HEALTH_URL=https://example.com/api/health
# Optional expected app version; leave empty to skip version match.
AREAFORGE_ALERT_EXPECTED_VERSION=

# Local read-only signal sources.
AREAFORGE_ALERT_UPDATE_AGENT_STATUS_FILE=/opt/areaforge/ops-state/status.json
AREAFORGE_ALERT_BACKUP_DIR=/opt/areaforge/backups
AREAFORGE_ALERT_DEPLOY_DIR=/opt/areaforge
# Optional: read certificate end date from a file instead of a TLS probe.
AREAFORGE_ALERT_CERT_FILE=
# Optional: override the TLS probe host (defaults to the health URL host).
AREAFORGE_ALERT_CERT_HOST=

# Thresholds. Defaults follow docs/development/production-smoke-alerting-strategy.md.
AREAFORGE_ALERT_BACKUP_MAX_AGE_HOURS=24
AREAFORGE_ALERT_UPDATE_AGENT_MAX_AGE_HOURS=26
AREAFORGE_ALERT_DISK_WARN_AVAIL_PERCENT=20
AREAFORGE_ALERT_DISK_CRIT_AVAIL_PERCENT=10
AREAFORGE_ALERT_CERT_WARN_DAYS=14
AREAFORGE_ALERT_CERT_CRIT_DAYS=7

# Dedup state and renotify window for unchanged degraded payloads.
AREAFORGE_ALERT_STATE_DIR=/opt/areaforge/ops-state/alerting
AREAFORGE_ALERT_RENOTIFY_MINUTES=360

# Receivers. Configure at least one for notify mode.
# ntfy topic URL, e.g. https://ntfy.sh/your-private-topic
AREAFORGE_ALERT_NTFY_URL=
# Optional ntfy access token file (chmod 600); the token value never goes into env.
AREAFORGE_ALERT_NTFY_TOKEN_FILE=
# Telegram: bot token lives in a chmod 600 file, chat id is not a secret.
AREAFORGE_ALERT_TELEGRAM_BOT_TOKEN_FILE=
AREAFORGE_ALERT_TELEGRAM_CHAT_ID=
# Generic webhook receiving the redacted summary JSON via POST.
AREAFORGE_ALERT_WEBHOOK_URL=
